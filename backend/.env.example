# Copy this to .env and fill in your keys

# LLM — Groq (preferred; OpenAI-compatible, generous free tier)
# Get a key at https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# Google Gemini (optional fallback if GROQ_API_KEY is not set)
GEMINI_API_KEY=
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemini-2.5-flash-lite


# Ollama (local fallback - only used in development when both Groq and Gemini fail)
# Requires Ollama to be installed and running: https://ollama.ai
# Pull the model first: ollama pull llama3.2
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Google Cloud Vision API (fallback OCR, 1000 units/month free)
GOOGLE_VISION_API_KEY=

# Google Search API (fallback web search, 100 queries/day free)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# App settings
DEBUG=false

# LLM Rate Limiting (prevents 429 errors from Groq)
LLM_MAX_CONCURRENT_REQUESTS=1
LLM_RETRY_ON_RATE_LIMIT=true
LLM_MIN_DELAY_BETWEEN_REQUESTS=2.0

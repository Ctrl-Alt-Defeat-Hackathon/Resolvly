# Copy this to .env and fill in your keys

# Google Gemini API (free tier)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Vision API (fallback OCR, 1000 units/month free)
GOOGLE_VISION_API_KEY=

# Google Search API (fallback web search, 100 queries/day free)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# App settings
DEBUG=false
